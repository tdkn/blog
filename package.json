    "remark-frontmatter": "5.0.0",
    "remark-mdx-frontmatter": "5.2.0",
    "shiki": "4.0.2",
    "tailwind-merge": "3.5.0"
  },
  "devDependencies": {
    "@mdx-js/rollup": "3.1.1",
    "@tailwindcss/forms": "0.5.11",
    "@tailwindcss/postcss": "4.2.2",
    "@testing-library/react": "16.3.2",
    "@types/mdx": "2.0.13",
