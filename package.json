    "fix:ultracite": "ultracite fix --type-aware --type-check",
    "fix:stylelint": "stylelint './src/**/*.css' -f verbose --fix",
    "test": "TZ='Asia/Tokyo' vitest",
    "postinstall": "husky"
  },
